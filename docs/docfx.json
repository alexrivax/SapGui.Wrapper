{
  "metadata": [
    {
      "src": [
        {
          "files": ["SapGui.Wrapper/SapGui.Wrapper.csproj"],
          "src": ".."
        },
        {
          "files": ["SapGui.Wrapper.Agent/SapGui.Wrapper.Agent.csproj"],
          "src": ".."
        },
        {
          "files": ["SapGui.Wrapper.Mcp/SapGui.Wrapper.Mcp.csproj"],
          "src": ".."
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": ["api/**.yml", "api/index.md"]
      },
      {
        "files": ["articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md"]
      }
    ],
    "resource": [
      {
        "files": ["images/**"]
      }
    ],
    "dest": "_site",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appTitle": "SapGui.Wrapper",
      "_appName": "SapGui.Wrapper",
      "_appFooter": "SapGui.Wrapper — MIT License — <a href='https://github.com/alexrivax/SapGui.Wrapper'>GitHub</a>",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/alexrivax/SapGui.Wrapper",
        "branch": "main"
      }
    },
    "markdownEngineVersion": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
